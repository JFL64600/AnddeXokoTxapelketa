<UserControl x:Class="AnddeXokoTxapelketa.Controls.ScoreDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnddeXokoTxapelketa.Controls"
             xmlns:materialDegign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="300">
    <UserControl.Resources>
        <Style x:Key="Player" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryHueMidBrush}" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="100" />
        </Grid.RowDefinitions>
        <materialDegign:ColorZone Mode="Standard" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                          VerticalContentAlignment="Stretch" Name="CZ">
            <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="White">
                <TextBlock Style="{StaticResource Player}" Name="PlayerLabel1" />
            </Grid>
        </materialDegign:ColorZone>
        <Grid Grid.Row="1">
            <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20,20,120,20" 
                    Style="{DynamicResource MaterialDesignFlatButton}" Click="CancelClick" Content="Cancel"/>
            <Button Margin="20" HorizontalAlignment="Right" VerticalAlignment="Center" Click="ValidClick" Content="Valid"/>
        </Grid>
        <!--<StackPanel>
            <TextBlock Text="Popup Title" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBox Name="TBTemp"/>
            <Button Content="Confirm" HorizontalAlignment="Center" Click="ValidClick"/>
            <Button Content="Cancel" HorizontalAlignment="Center" Click="CancelClick"/>
        </StackPanel>-->
    </Grid>
</UserControl>
