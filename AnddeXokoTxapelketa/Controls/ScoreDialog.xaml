<UserControl x:Class="AnddeXokoTxapelketa.Controls.ScoreDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnddeXokoTxapelketa.Controls"
             xmlns:materialDegign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="75" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <local:PlayerLabel Grid.Row="0" Grid.Column="0" x:Name="Player1"></local:PlayerLabel>
            <local:Score Grid.Row="0" Grid.Column="1" x:Name="Score1"></local:Score>
            <local:PlayerLabel Grid.Row="1" Grid.Column="0" x:Name="Player2"></local:PlayerLabel>
            <local:Score Grid.Row="1" Grid.Column="1" x:Name="Score2"></local:Score>
        </Grid>
        <materialDegign:ColorZone Grid.Row="1" Mode="PrimaryMid" HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch" VerticalContentAlignment="Stretch" BorderThickness="1" BorderBrush="Black">
            <Grid>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20,20,120,20" 
                        Style="{DynamicResource MaterialDesignRaisedDarkButton}" Click="CancelClick" Content="Bazter utzi"/>
                <Button Margin="20" HorizontalAlignment="Right" VerticalAlignment="Center" Click="ValidClick" 
                        Content="Egiazkotu"/>
            </Grid>
        </materialDegign:ColorZone>
    </Grid>
</UserControl>
