<UserControl x:Class="AnddeXokoTxapelketa.Controls.Create"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnddeXokoTxapelketa.Controls"
             xmlns:materialDegign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>
        <materialDegign:ColorZone Grid.Row="0" Mode="PrimaryMid" HorizontalAlignment="Stretch" 
                                  VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >
                <TextBlock Style="{DynamicResource MaterialDesignBody1TextBlock}" FontSize="30" Margin="15" VerticalAlignment="Bottom">Nouveau tournoi</TextBlock>
            </Grid>
        </materialDegign:ColorZone>
        <Grid Grid.Row="2">
            <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="Bazter utzi" Margin="20,20,120,20"
                    Style="{DynamicResource MaterialDesignFlatButton}" Command="{x:Static materialDegign:Transitioner.MovePreviousCommand}"/>
            <Button Margin="20" Name="bCreate" IsEnabled="False" HorizontalAlignment="Right" VerticalAlignment="Center" Click="CreateClick" Content="Create"/>
        </Grid>
        <StackPanel Grid.Row="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="left" Margin="10">
                <TextBox Name="tbName" FontSize="25" Text="" TextChanged="TextChanged"
                         Style="{DynamicResource MaterialDesignTextBox}" 
                         HorizontalAlignment="Left" TextWrapping="Wrap" Width="300"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="left" Margin="10">
                <Label Name="lGirls" Content="Joueuses" Margin="10,5,2,5" FontSize="20"
                       Style="{DynamicResource MaterialDesignLabel}" HorizontalAlignment="Left"/>
                <TextBox Name="tbGirls" Tag="Players" Margin="2,5,20,5" FontSize="20"
                         Style="{DynamicResource MaterialDesignTextBox}" 
                         HorizontalAlignment="Left" TextWrapping="Wrap" Text="" Width="40"
                         TextAlignment="Right" PreviewTextInput="PreviewTextInput"
                         TextChanged="TextChanged"/>
                <Label Name="lGirlsGroups" Content="Groupes" Margin="20,5,2,5" FontSize="20"
                       Style="{DynamicResource MaterialDesignLabel}" HorizontalAlignment="Left"/>
                <TextBox Name="tbGirlsGroups" Tag="Groups" Margin="2,5,2,5" FontSize="20"
                         Style="{DynamicResource MaterialDesignTextBox}" TextChanged="TextChanged"
                         HorizontalAlignment="Left" TextWrapping="Wrap" Text="" Width="50"
                         TextAlignment="Right" PreviewTextInput="PreviewTextInput"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="left" Margin="10">
                <Label Name="lBoys" Content="Joueurs" Margin="10,5,2,5" FontSize="20"
                       Style="{DynamicResource MaterialDesignLabel}" HorizontalAlignment="Left"/>
                <TextBox Name="tbBoys" Tag="Players" Margin="2,5,20,5" FontSize="20"
                         Style="{DynamicResource MaterialDesignTextBox}" TextChanged="TextChanged"
                         HorizontalAlignment="Left" TextWrapping="Wrap" Text="" Width="40"
                         TextAlignment="Right" PreviewTextInput="PreviewTextInput"/>
                <Label Name="lBoysGroups" Content="Groupes" Margin="20,5,2,5" FontSize="20"
                       Style="{DynamicResource MaterialDesignLabel}" HorizontalAlignment="Left"/>
                <TextBox Name="tbBoysGroups" Tag="Groups" Margin="2,5,2,5" FontSize="20"
                         Style="{DynamicResource MaterialDesignTextBox}" TextChanged="TextChanged"
                         HorizontalAlignment="Left" TextWrapping="Wrap" Text="" Width="50"
                         TextAlignment="Right" PreviewTextInput="PreviewTextInput"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
