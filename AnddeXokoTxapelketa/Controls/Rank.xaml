<UserControl x:Class="AnddeXokoTxapelketa.Controls.Rank"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnddeXokoTxapelketa.Controls"
             xmlns:materialDegign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="Player" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryHueMidBrush}" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="150" />
            <RowDefinition Height="*" />
            <RowDefinition Height="100" />
        </Grid.RowDefinitions>
        <materialDegign:ColorZone Grid.Row="0" Mode="PrimaryMid" HorizontalAlignment="Stretch" 
                                  VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >
                <TextBlock Style="{DynamicResource MaterialDesignHeadline1TextBlock}"
                           FontSize="30" Margin="15" VerticalAlignment="Bottom" Name="tbTitle" />
            </Grid>
        </materialDegign:ColorZone>
        <Grid Grid.Row="1" Margin="0,0,0,0" Name="gResult">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0.5*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <local:RankGroup Grid.Row="0" Grid.Column="0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" x:Name="N1"></local:RankGroup>
            <local:RankGroup Grid.Row="0" Grid.Column="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" x:Name="N2"></local:RankGroup>
            <ListView Grid.Row="0" Grid.Column="2" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <ListViewItem>
                    <TextBlock Text=""></TextBlock>
                </ListViewItem>
                <ListViewItem>
                    <TextBlock Text=""></TextBlock>
                </ListViewItem>
                <ListViewItem>
                    <TextBlock Text=""></TextBlock>
                </ListViewItem>
                <ListViewItem>
                    <TextBlock Text=""></TextBlock>
                </ListViewItem>
                <ListViewItem>
                    <TextBlock Text=""></TextBlock>
                </ListViewItem>
                <ListViewItem>
                    <TextBlock Text=""></TextBlock>
                </ListViewItem>
                <ListViewItem>
                    <TextBlock Text=""></TextBlock>
                </ListViewItem>
                <ListViewItem>
                    <TextBlock Text=""></TextBlock>
                </ListViewItem>
                <ListViewItem>
                    <TextBlock Text=""></TextBlock>
                </ListViewItem>
            </ListView>
            <local:RankGroup Grid.Row="0" Grid.Column="3" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" x:Name="M1"></local:RankGroup>
            <local:RankGroup Grid.Row="0" Grid.Column="4" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" x:Name="M2"></local:RankGroup>
            <local:RankGroup Grid.Row="0" Grid.Column="5" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" x:Name="M3"></local:RankGroup>
            <local:RankGroup Grid.Row="0" Grid.Column="6" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" x:Name="M4"></local:RankGroup>
            <local:RankGroup Grid.Row="0" Grid.Column="7" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" x:Name="M5"></local:RankGroup>
            <local:RankGroup Grid.Row="0" Grid.Column="8" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" x:Name="M6"></local:RankGroup>
        </Grid>
        <Grid Grid.Row="2">
            <Button Margin="20" Click="CloseRankClick" HorizontalAlignment="Right" VerticalAlignment="Center" Content="Close" />
        </Grid>
    </Grid>
</UserControl>
