<UserControl x:Class="AnddeXokoTxapelketa.Controls.RankGroup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnddeXokoTxapelketa.Controls"
             xmlns:materialDegign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="GroupName" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <materialDegign:ColorZone Mode="Standard" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                          VerticalContentAlignment="Stretch">
            <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="{DynamicResource PrimaryHueMidBrush}">
                <TextBlock Style="{StaticResource GroupName}" Name="GroupName" TextAlignment="Center" />
            </Grid>
        </materialDegign:ColorZone>
        <local:RankPlayerLabel Grid.Row="1" x:Name="Player1"></local:RankPlayerLabel>
        <local:RankPlayerLabel Grid.Row="2" x:Name="Player2"></local:RankPlayerLabel>
        <local:RankPlayerLabel Grid.Row="3" x:Name="Player3"></local:RankPlayerLabel>
        <local:RankPlayerLabel Grid.Row="4" x:Name="Player4"></local:RankPlayerLabel>
        <local:RankPlayerLabel Grid.Row="5" x:Name="Player5"></local:RankPlayerLabel>
        <local:RankPlayerLabel Grid.Row="6" x:Name="Player6"></local:RankPlayerLabel>
        <local:RankPlayerLabel Grid.Row="7" x:Name="Player7"></local:RankPlayerLabel>
        <local:RankPlayerLabel Grid.Row="8" x:Name="Player8"></local:RankPlayerLabel>
    </Grid>
</UserControl>