<UserControl x:Class="AnddeXokoTxapelketa.Controls.Show"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnddeXokoTxapelketa.Controls"
             xmlns:materialDegign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="ResultBorder" TargetType="Border">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}" />
        </Style>
        <Style x:Key="TBResult" TargetType="TextBox">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}" />
        </Style>
        <Style x:Key="TBResultPlayer" TargetType="TextBox" BasedOn="{StaticResource TBResult}">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryHueMidBrush}" />
        </Style>
        <Style x:Key="TBResultScore" TargetType="TextBox" BasedOn="{StaticResource TBResult}">
            <Setter Property="FontSize" Value="25" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryHueMidBrush}" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
        <Style x:Key="ResultPlayerLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryHueMidBrush}" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="150" />
            <RowDefinition Height="*" />
            <RowDefinition Height="100" />
        </Grid.RowDefinitions>
        <materialDegign:ColorZone Grid.Row="0" Mode="PrimaryMid" HorizontalAlignment="Stretch" 
                                  VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >
                <TextBlock Style="{DynamicResource MaterialDesignHeadline1TextBlock}"
                           FontSize="30" Margin="15" VerticalAlignment="Bottom" Name="tbTitle" />
            </Grid>
        </materialDegign:ColorZone>
        <Grid Grid.Row="1" Margin="0,0,20,0" Name="gResult">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Row="0" Grid.Column="0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Border Style="{StaticResource ResultBorder}" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button Style="{DynamicResource MaterialDesignOutlinedDarkButton}" Margin="1" Name="BPrevious" Click="BPreviousClick">
                        <materialDegign:PackIcon Kind="ArrowLeftBold"/>
                    </Button>
                    <TextBlock Style="{DynamicResource MaterialDesignHeadline1TextBlock}" Foreground="{DynamicResource PrimaryHueMidBrush}"
                               FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center"
                               Margin="2" Name="TBGroup">
                    </TextBlock>
                    <Button Style="{DynamicResource MaterialDesignOutlinedDarkButton}" Margin="1" Name="BNext" Click="BNextClick">
                        <materialDegign:PackIcon Kind="ArrowRightBold"/>
                    </Button>
                </StackPanel>
            </Grid>
            <local:Diagonal Grid.Row="1" Grid.Column="1" x:Name="Diagonal1"></local:Diagonal>
            <local:Diagonal Grid.Row="2" Grid.Column="2" x:Name="Diagonal2"></local:Diagonal>
            <local:Diagonal Grid.Row="3" Grid.Column="3" x:Name="Diagonal3"></local:Diagonal>
            <local:Diagonal Grid.Row="4" Grid.Column="4" x:Name="Diagonal4"></local:Diagonal>
            <local:Diagonal Grid.Row="5" Grid.Column="5" x:Name="Diagonal5"></local:Diagonal>
            <local:Diagonal Grid.Row="6" Grid.Column="6" x:Name="Diagonal6"></local:Diagonal>
            <local:Diagonal Grid.Row="7" Grid.Column="7" x:Name="Diagonal7"></local:Diagonal>
            <local:Diagonal Grid.Row="8" Grid.Column="8" x:Name="Diagonal8"></local:Diagonal>
            <local:PlayerName Grid.Row="1" Grid.Column="0" x:Name="PlayerName1" ExitEvent="PlayerNameExitEvent"></local:PlayerName>
            <local:PlayerName Grid.Row="2" Grid.Column="0" x:Name="PlayerName2" ExitEvent="PlayerNameExitEvent"></local:PlayerName>
            <local:PlayerName Grid.Row="3" Grid.Column="0" x:Name="PlayerName3" ExitEvent="PlayerNameExitEvent"></local:PlayerName>
            <local:PlayerName Grid.Row="4" Grid.Column="0" x:Name="PlayerName4" ExitEvent="PlayerNameExitEvent"></local:PlayerName>
            <local:PlayerName Grid.Row="5" Grid.Column="0" x:Name="PlayerName5" ExitEvent="PlayerNameExitEvent"></local:PlayerName>
            <local:PlayerName Grid.Row="6" Grid.Column="0" x:Name="PlayerName6" ExitEvent="PlayerNameExitEvent"></local:PlayerName>
            <local:PlayerName Grid.Row="7" Grid.Column="0" x:Name="PlayerName7" ExitEvent="PlayerNameExitEvent"></local:PlayerName>
            <local:PlayerName Grid.Row="8" Grid.Column="0" x:Name="PlayerName8" ExitEvent="PlayerNameExitEvent"></local:PlayerName>
            <local:PlayerLabel Grid.Row="0" Grid.Column="1" x:Name="PlayerLabel1"></local:PlayerLabel>
            <local:PlayerLabel Grid.Row="0" Grid.Column="2" x:Name="PlayerLabel2"></local:PlayerLabel>
            <local:PlayerLabel Grid.Row="0" Grid.Column="3" x:Name="PlayerLabel3"></local:PlayerLabel>
            <local:PlayerLabel Grid.Row="0" Grid.Column="4" x:Name="PlayerLabel4"></local:PlayerLabel>
            <local:PlayerLabel Grid.Row="0" Grid.Column="5" x:Name="PlayerLabel5"></local:PlayerLabel>
            <local:PlayerLabel Grid.Row="0" Grid.Column="6" x:Name="PlayerLabel6"></local:PlayerLabel>
            <local:PlayerLabel Grid.Row="0" Grid.Column="7" x:Name="PlayerLabel7"></local:PlayerLabel>
            <local:PlayerLabel Grid.Row="0" Grid.Column="8" x:Name="PlayerLabel8"></local:PlayerLabel>
            <local:Score Grid.Row="1" Grid.Column="2" x:Name="ScoreR1C2" ExitEvent="ScoreExitEvent" MouseDoubleClick="OpenScore"></local:Score>
            <local:Score Grid.Row="1" Grid.Column="3" x:Name="ScoreR1C3" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="1" Grid.Column="4" x:Name="ScoreR1C4" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="1" Grid.Column="5" x:Name="ScoreR1C5" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="1" Grid.Column="6" x:Name="ScoreR1C6" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="1" Grid.Column="7" x:Name="ScoreR1C7" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="1" Grid.Column="8" x:Name="ScoreR1C8" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="2" Grid.Column="1" x:Name="ScoreR2C1" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="2" Grid.Column="3" x:Name="ScoreR2C3" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="2" Grid.Column="4" x:Name="ScoreR2C4" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="2" Grid.Column="5" x:Name="ScoreR2C5" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="2" Grid.Column="6" x:Name="ScoreR2C6" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="2" Grid.Column="7" x:Name="ScoreR2C7" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="2" Grid.Column="8" x:Name="ScoreR2C8" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="3" Grid.Column="1" x:Name="ScoreR3C1" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="3" Grid.Column="2" x:Name="ScoreR3C2" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="3" Grid.Column="4" x:Name="ScoreR3C4" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="3" Grid.Column="5" x:Name="ScoreR3C5" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="3" Grid.Column="6" x:Name="ScoreR3C6" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="3" Grid.Column="7" x:Name="ScoreR3C7" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="3" Grid.Column="8" x:Name="ScoreR3C8" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="4" Grid.Column="1" x:Name="ScoreR4C1" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="4" Grid.Column="2" x:Name="ScoreR4C2" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="4" Grid.Column="3" x:Name="ScoreR4C3" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="4" Grid.Column="5" x:Name="ScoreR4C5" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="4" Grid.Column="6" x:Name="ScoreR4C6" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="4" Grid.Column="7" x:Name="ScoreR4C7" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="4" Grid.Column="8" x:Name="ScoreR4C8" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="5" Grid.Column="1" x:Name="ScoreR5C1" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="5" Grid.Column="2" x:Name="ScoreR5C2" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="5" Grid.Column="3" x:Name="ScoreR5C3" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="5" Grid.Column="4" x:Name="ScoreR5C4" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="5" Grid.Column="6" x:Name="ScoreR5C6" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="5" Grid.Column="7" x:Name="ScoreR5C7" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="5" Grid.Column="8" x:Name="ScoreR5C8" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="6" Grid.Column="1" x:Name="ScoreR6C1" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="6" Grid.Column="2" x:Name="ScoreR6C2" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="6" Grid.Column="3" x:Name="ScoreR6C3" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="6" Grid.Column="4" x:Name="ScoreR6C4" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="6" Grid.Column="5" x:Name="ScoreR6C5" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="6" Grid.Column="7" x:Name="ScoreR6C7" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="6" Grid.Column="8" x:Name="ScoreR6C8" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="7" Grid.Column="1" x:Name="ScoreR7C1" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="7" Grid.Column="2" x:Name="ScoreR7C2" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="7" Grid.Column="3" x:Name="ScoreR7C3" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="7" Grid.Column="4" x:Name="ScoreR7C4" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="7" Grid.Column="5" x:Name="ScoreR7C5" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="7" Grid.Column="6" x:Name="ScoreR7C6" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="7" Grid.Column="8" x:Name="ScoreR7C8" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="8" Grid.Column="1" x:Name="ScoreR8C1" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="8" Grid.Column="2" x:Name="ScoreR8C2" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="8" Grid.Column="3" x:Name="ScoreR8C3" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="8" Grid.Column="4" x:Name="ScoreR8C4" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="8" Grid.Column="5" x:Name="ScoreR8C5" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="8" Grid.Column="6" x:Name="ScoreR8C6" ExitEvent="ScoreExitEvent"></local:Score>
            <local:Score Grid.Row="8" Grid.Column="7" x:Name="ScoreR8C7" ExitEvent="ScoreExitEvent"></local:Score>
        </Grid>
        <Grid Grid.Row="2">
            <Button Margin="20" Click="CloseTournamentClick" HorizontalAlignment="Right" VerticalAlignment="Center" Content="Close" />
        </Grid>
        <Popup Name="popup" IsOpen="False" StaysOpen="False" Placement="Center">
            <local:ScoreDialog/>
        </Popup>
    </Grid>
</UserControl>
